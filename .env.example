# Домен, на котором будет крутиться сайт (используется в nginx/server_name).
DOMAIN=example.com

# Runtime-настройки Nitro/Nuxt внутри контейнера app.
# Менять обычно не нужно — значения совпадают с дефолтами в docker-compose.yml.
NODE_ENV=production
NITRO_HOST=0.0.0.0
NITRO_PORT=3000

# Если потребуется задать публичный URL для SSR/мета-тегов — раскомментируйте
# и подставьте свой домен:
# NUXT_PUBLIC_SITE_URL=https://example.com

# Integration API gogol_tasks (портфолио). Тот же секрет, что INTEGRATION_SECRET в gogol_tasks/.env
INTEGRATION_SECRET=change-me-integration-secret
# В Docker-сети web (прод):
GOGOL_DASHBOARD_BASE_URL=http://gogol-dashboard:3000/dashboard
# Локально без Docker-сети:
# GOGOL_DASHBOARD_BASE_URL=http://178.250.158.178/dashboard
