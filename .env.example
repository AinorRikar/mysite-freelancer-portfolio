# Домен, на котором будет крутиться сайт (используется в nginx/server_name).
DOMAIN=example.com

# Runtime-настройки Nitro/Nuxt внутри контейнера app.
# Менять обычно не нужно — значения совпадают с дефолтами в docker-compose.yml.
NODE_ENV=production
NITRO_HOST=0.0.0.0
NITRO_PORT=3000

# Если потребуется задать публичный URL для SSR/мета-тегов — раскомментируйте
# и подставьте свой домен:
# NUXT_PUBLIC_SITE_URL=https://example.com
